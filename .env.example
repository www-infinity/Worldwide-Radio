# Worldwide Radio - Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.

# Radio Browser API - No key needed (public, free, CORS-enabled)
# Documentation: https://api.radio-browser.info/
RADIO_BROWSER_BASE_URL=https://de1.api.radio-browser.info/json

# Optional: RapidAPI key for RadioAPI (90,000+ stations, 300 req/month free)
# Sign up at: https://rapidapi.com/
# RAPIDAPI_KEY=your_rapidapi_key_here
